    <!-- Shopping Cart -->

    <form class="bg0 p-t-75 p-b-85">
      <div class="container">
        <div class="row">
          <% let hasUnavailable=false; %>

            <% if (cartItems && cartItems.length> 0) { %>

              <!-- CART TABLE -->
              <div class="col-lg-10 col-xl-7 m-lr-auto m-b-50">
                <div class="wrap-table-shopping-cart">
                  <table class="table-shopping-cart">
                    <thead>
                      <tr class="table_head">
                        <th class="column-1">Product</th>
                        <th class="column-2"></th>
                        <th class="column-6">Size</th>
                        <th class="column-3">Price</th>
                        <th class="column-4">Quantity</th>
                        <th class="column-5">Total</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% cartItems.forEach((item)=> { %>

                        <% const variant=item.productVariantId; %>
                          <% const sizeObj=variant.sizes?.find(s=> s.size === item.selectedSize); %>
                            <% const sizeStock=sizeObj?.stock || 0; %>

                              <% const unavailable=!variant.variantListed || !variant.productId?.listed || sizeStock
                                <=0; %>

                                <% const rowTotal=variant.variantPrice * item.quantity; %>

                                  <tr class="table_row" data-variant-id="<%= variant._id %>"
                                    data-size="<%= item.selectedSize %>" data-stock="<%= sizeStock %>"
                                    data-price="<%= variant.variantPrice %>"
                                    data-variant-name="<%= variant.variantName  %>">

                                    <!-- IMAGE + DELETE -->
                                    <td class="column-1">
                                      <div class="how-itemcart1 js-delete-cart">
                                        <img src="<%= variant.variantImg?.[0] %>" alt="Image">
                                      </div>
                                    </td>

                                    <!-- NAME -->
                                    <td class="column-2">
                                      <%= variant.variantName %> - <%= variant.variantColor %>
                                    </td>

                                    <% if (unavailable) { %>

                                      <td colspan="4" style="color:red;">
                                        Product unavailable at this moment
                                      </td>

                                      <% } else { %>

                                        <!-- SIZE -->
                                        <td class="column-6">
                                          <%= item.selectedSize %>
                                        </td>

                                        <!-- PRICE -->
                                        <td class="column-3 js-price">
                                          ₹ <%= variant.variantPrice.toLocaleString() %>
                                        </td>

                                        <!-- QUANTITY -->
                                        <td class="column-4">
                                          <div class="wrap-num-product flex-w m-l-auto m-r-0">

                                            <button type="button"
                                              class="btn-num-product-down js-qty-decrement cl8 hov-btn3 trans-04 flex-c-m">
                                              <i class="fs-16 zmdi zmdi-minus"></i>
                                            </button>

                                            <span class="mtext-104 cl3 txt-center num-product js-qty">
                                              <%= item.quantity %>
                                            </span>

                                            <button type="button"
                                              class="btn-num-product-up js-qty-increment cl8 hov-btn3 trans-04 flex-c-m">
                                              <i class="fs-16 zmdi zmdi-plus"></i>
                                            </button>

                                          </div>
                                        </td>

                                        <!-- ROW TOTAL -->
                                        <td class="column-5 qPrice js-row-total">
                                          ₹ <%= rowTotal.toLocaleString() %>
                                        </td>

                                        <% } %>
                                  </tr>

                                  <% }) %>
                    </tbody>


                  </table>
                </div>

                <!-- CONTINUE SHOPPING -->
                <div class="flex-c-m stext-101 size-119 bg8 bor13 p-lr-15 m-t-15">
                  <a href="/shop_products">Continue Shopping</a>
                </div>
              </div>

              <% } else { %>

                <!-- EMPTY CART -->
                <div class="col-12 text-center py-5">
                  <img src="/images/empty cart.webp" width="150" />
                  <h4>Your Cart is Empty!</h4>
                  <a href="/shop_products" class="btn btn-primary mt-3">Start Shopping</a>
                </div>

                <% } %>


                  <!-- CART TOTALS -->
                  <div class="col-sm-10 col-lg-7 col-xl-5 m-lr-auto m-b-50">
                    <div class="bor10 p-4">

                      <h4 class="mtext-109 cl2 p-b-20">Cart Totals</h4>

                      <div class="flex-w flex-t p-b-20">
                        <span class="mtext-101 cl2">Total:</span>
                        <span class="mtext-110 cl2 ml-auto" id="cartTotal">
                          ₹ <%= typeof cartTotal !=="undefined" ? cartTotal.toLocaleString() : "0" %>
                        </span>
                      </div>

                      <!-- CHECKOUT BUTTON -->
                      <% if (!hasUnavailable && cartItems && cartItems.length> 0) { %>
                        <a href="/checkout" class="flex-c-m stext-101 cl0 size-116 bg3 bor14 p-lr-15">
                          Proceed to Checkout
                        </a>
                        <% } else { %>
                          <button class="size-116 bg-secondary text-white" disabled>
                            Unavailable items in cart
                          </button>
                          <% } %>

                    </div>
                  </div>

        </div>
      </div>
    </form>






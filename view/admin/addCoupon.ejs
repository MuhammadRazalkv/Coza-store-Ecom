<%- include('../layouts/adminHeader') %>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
<link rel="stylesheet" href="/css/userSideCSS/ToastMessage.css">
<style>

  .ac-header {
  text-align: center;
  margin-bottom: 10px; /* Reduced margin */
}

.ac-container {
  max-width: 600px;
  margin: 0 auto;
}

.ac-card {
  background-color: #191c24;
  padding: 20px; /* Reduced padding */
  border-radius: 15px;
  margin-top: 30px;
  box-shadow: 0 4px 8px rgba(0, 0, 0, 0.3);
}

.ac-card h2 {
  color: #bdbdae;
  margin-bottom: 15px; /* Reduced margin */
  font-size: 24px;
  text-align: center;
}

.ac-form-group label {
  color: #bdbdae;
  font-weight: bold;
}

.ac-form-group input,
.ac-form-group select {
  background-color: #2e2e2e;
  color: #bdbdae;
  border: 1px solid #444444;
  border-radius: 5px;
  padding: 8px; /* Reduced padding */
  margin-bottom: 10px; /* Reduced margin */
  width: 100%;
}

.ac-btn {
  padding: 8px 15px; /* Reduced padding */
  border: none;
  border-radius: 5px;
  cursor: pointer;
  font-size: 14px;
  transition: background-color 0.3s;
  width: 100%;
  margin-bottom: 10px;
}

.ac-btn-submit {
  background-color: #2196F3;
  color: #ffffff;
}

.ac-btn-submit:hover {
  background-color: #1e88e5;
}

.ac-btn-cancel {
  background-color: #e82e21;
  color: #ffffff;
}

.ac-btn-cancel:hover {
  background-color: #e53935;
}

#alertMessage {
  display: none;
}

</style>

<body>
  <div class="container-fluid position-relative d-flex p-0">
    <!-- Spinner Start -->
    <div id="spinner" class="show bg-dark position-fixed translate-middle w-100 vh-100 top-50 start-50 d-flex align-items-center justify-content-center">
      <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status">
        <span class="sr-only">Loading...</span>
      </div>
    </div>
    <!-- Spinner End -->


    <!-- Sidebar Start -->
    <div class="sidebar pe-4 pb-3">
      <nav class="navbar bg-secondary navbar-dark">
        <a href="/admin" class="navbar-brand mx-4 mb-3">
          <h3 class="text-primary"><i class="fa fa-user-edit me-2"></i>Admin</h3>
        </a>
        <div class="d-flex align-items-center ms-4 mb-4">
          <!-- <div class="position-relative">
            <img class="rounded-circle" src="" alt="" style="width: 40px; height: 40px;">
            <div class="bg-success rounded-circle border border-2 border-white position-absolute end-0 bottom-0 p-1"></div>
          </div> -->
          <div class="ms-3">
            <h6 class="mb-0"> Doe</h6>
            <span>Admin</span>
          </div>
        </div>
        <div class="navbar-nav w-100">
          <a href="/admin" class="nav-item nav-link "><i class="fa fa-tachometer-alt me-2"></i>Dashboard</a>

          <a href="/admin/user-List" class="nav-item nav-link "><i class="fa fa-users me-2"></i>Users</a>
          <a href="/admin/category-list" class="nav-item nav-link"><i class="fa fa-keyboard me-2"></i>Category</a>
          <a href="/admin/products-list" class="nav-item nav-link"><i class="fa fa-bell me-2"></i>Products</a>
          <a href="/admin/orderDetails" class="nav-item nav-link"><i class="fa fa-chart-area me-2"></i>Orders</a>
          <a href="/admin/couponList" class="nav-item nav-link active"><i class="fa fa-chart-bar me-2"></i>Coupons</a>


          <a href="/admin/logout" class="nav-item nav-link"> <i class="fa fa-sign-out-alt"></i>Logout</a>
        </div>
    </div>
    </nav>
  </div>

  <!-- Sidebar End -->
  <div class="content">
    <!-- Navbar Start -->
    <nav class="navbar navbar-expand bg-secondary navbar-dark sticky-top px-4 py-0">
      <a href="" class="navbar-brand d-flex d-lg-none me-4">
        <h2 class="text-primary mb-0"><i class="fa fa-user-edit"></i></h2>
      </a>
      <a href="#" class="sidebar-toggler flex-shrink-0">
        <i class="fa fa-bars"></i>
      </a>
    
    </nav>

  <div class="container ac-container">
    <div class="ac-card">
      <h2>Create a New Coupon</h2>
      <form id="addCoupon">

        <div class="alert alert-danger" role="alert" id="alertMessage">
          This is alert message
        </div>

        <div class="form-group ac-form-group">
          <label for="couponCode">Coupon Name</label>
          <input type="text" class="form-control" id="couponName" placeholder="Enter coupon name">
        </div>

        <div class="form-group ac-form-group">
            <label for="couponCode">Coupon Code</label>
            <input type="text" class="form-control" id="couponCode" placeholder="Enter coupon code">
          </div>
        <div class="form-group ac-form-group">
            <label for="minimumPurchaseAmount">Minimum purchase amount</label>
            <input type="number" class="form-control numberVal" id="minimumPurchaseAmount" placeholder="Enter minimum purchase amount" min="0">
          </div>
          
          <div class="form-group ac-form-group">
            <label for="discountPercentage">Discount Percentage</label>
            <input type="number" class="form-control numberVal" id="discountPercentage" placeholder="Enter discount percentage" min="0">
          </div>
          
          <div class="form-group ac-form-group">
            <label for="maxRedeemAmount">Maximum redeem amount</label>
            <input type="number" class="form-control numberVal" id="maxRedeemAmount" placeholder="Enter maximum amount" min="0">
          </div>
          
        <div class="form-group ac-form-group">
          <label for="expiryDate">Expiry Date</label>
          <input type="date" class="form-control" id="expiryDate">
        </div>
        
        <button type="submit" class="ac-btn ac-btn-submit">Add Coupon</button>
        <a href="/admin/couponList"><button  type="button" class="ac-btn ac-btn-cancel">Cancel</button></a>
      </form>
    </div>
  </div>
  
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="/js/adminFunctions/coupon.js"></script>

<%- include('../layouts/adminfooter') %>
<%- include('../layouts/adminHeader') %>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
  <link rel="stylesheet" href="/css/productDetailsAdmin.css">

  <body>
    <div class="container-fluid position-relative d-flex p-0">
      <!-- Spinner Start -->
      <div id="spinner"
        class="show bg-dark position-fixed translate-middle w-100 vh-100 top-50 start-50 d-flex align-items-center justify-content-center">
        <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status">
          <span class="sr-only">Loading...</span>
        </div>
      </div>
      <!-- Spinner End -->


      <!-- Sidebar Start -->
      <div class="sidebar pe-4 pb-3">
        <nav class="navbar bg-secondary navbar-dark">
          <a href="/admin" class="navbar-brand mx-4 mb-3">
            <h3 class="text-primary"><i class="fa fa-user-edit me-2"></i>Admin</h3>
          </a>
          <div class="d-flex align-items-center ms-4 mb-4">
            <!-- <div class="position-relative">
            <img class="rounded-circle" src="" alt="" style="width: 40px; height: 40px;">
            <div class="bg-success rounded-circle border border-2 border-white position-absolute end-0 bottom-0 p-1"></div>
          </div> -->
            <div class="ms-3">
              <h6 class="mb-0"> Doe</h6>
              <span>Admin</span>
            </div>
          </div>
          <div class="navbar-nav w-100">
            <a href="/admin" class="nav-item nav-link"><i class="fa fa-tachometer-alt me-2"></i>Dashboard</a>

            <a href="/admin/user-List" class="nav-item nav-link "><i class="fa fa-users me-2"></i>Users</a>
            <a href="/admin/category-list" class="nav-item nav-link "><i class="fa fa-keyboard me-2"></i>Category</a>
            <a href="/admin/products-list" class="nav-item nav-link"><i class="fa fa-bell me-2"></i>Products</a>
            <a href="/admin/orderDetails" class="nav-item nav-link active"><i
                class="fa fa-chart-area me-2"></i>Orders</a>
            <a href="/admin/couponList" class="nav-item nav-link"><i class="fa fa-chart-bar me-2"></i>Coupons</a>

            <a href="/admin/salesReport" class="nav-item nav-link"><i class="fa fa-file-invoice-dollar me-2"></i>Sales
              report</a>
            <a href="/admin/offers" class="nav-item nav-link"><i class="fa fa-file-invoice-dollar me-2"></i>Offers</a>
            <a href="/admin/logout" class="nav-item nav-link"> <i class="fa fa-sign-out-alt"></i>Logout</a>
          </div>
      </div>
      </nav>
    </div>
    <!-- Sidebar End -->


    <!-- Content Start -->
    <div class="content">
      <!-- Navbar Start -->
      <nav class="navbar navbar-expand bg-secondary navbar-dark sticky-top px-4 py-0">
        <a href="index.html" class="navbar-brand d-flex d-lg-none me-4">
          <h2 class="text-primary mb-0"><i class="fa fa-user-edit"></i></h2>
        </a>
        <a href="#" class="sidebar-toggler flex-shrink-0">
          <i class="fa fa-bars"></i>
        </a>

      </nav>
      <!-- Navbar End -->


      <div class="container product-container">
        <div id="heading">
          <h3 class="mb-4">Order Details</h3>
        </div>


        <% if (error) { %>
          <div class="alert alert-danger text-center">
            <%= error %>
          </div>

          <div class="text-center">
            <a href="/admin/orderDetails" class="btn btn-secondary">Back to List</a>
          </div>

          <% } else { %>
            <div class="row mb-3">
              <div class="col-md-12">
                <label for="productName">User Name:</label>
                <p id="productName">
                  <%= order.userId.name %>
                </p>
              </div>
            </div>

            <div class="row d-flex  mb-3">
              <div class="col-md-5">
                <div>
                  <label for="productDescription">Shipping Address:</label>
                  <p>
                    <% Object.entries(order.shippingAddress).forEach(([key, value])=> { %>
                      <%= key %>: <%= value %> <br>
                          <% }); %>
                  </p>
                </div>

              </div>
              <div class="col-md-5">
                <label for="productDescription">Order Details:</label>
                <p>Payment Method : <%= order.paymentMethod %><br>
                    Subtotal : <%= order.subTotal %> <br>
                      <% if (order.couponDetails.claimedAmount) { %>
                        Coupon discount : <%= order.couponDetails.claimedAmount %><br>
                          <% } else { %>
                            Coupon discount : 0 <br>
                            <% } %>
                              Offer discount :<%= order.totalOfferDiscount %><br>
                                Delivery Charge : <%= order.deliveryCharge %></br>
                                  <strong>Grand Total : <%= order.grandTotal %></strong></p>
              </div>

            </div>
      </div>

      <!--* ======== Order Details ========== -->

      <table class="product-table mb-3">
        <tbody>
          <tr>
            <th>Products</th>
            <th>Name</th>
            <th>Price</th>
            <th>Quantity </th>
            <th>Total</th>
            <th>Payment Method</th>
            <th>Status</th>
            <th>Action</th>

          </tr>
          <% if (order && order.orderItems.length>0) { %>
            <% order.orderItems.forEach(item=> { %>
              <tr>
                <td><img style="height: 40px; width: 40px;" src="<%= item.variantId.variantImg[0] %>"
                    alt="Product Image"></td>
                <td>
                  <%= item.variantName %>
                </td>
                <td>
                  <%= item.variantPrice %>
                </td>
                <td>
                  <%= item.quantity%>
                </td>
                <td>
                  <%= (item.quantity * item.variantPrice) %>
                </td>
                <td>
                  <%= order.paymentMethod %>
                </td>
                <td>
                  <%= item.orderStatus %>
                </td>
                <td>
                  <select class="form-control status-select " style="color: white; background-color: rgb(226, 55, 55);"
                    data-order-id="<%= order._id %>" data-variant-id="<%= item.variantId._id %>"
                    data-current-status="<%= item.orderStatus %>">
                    <% const currentStatus=item.orderStatus; const nextStatuses=validStatusTransitions[currentStatus] ||
                      []; %>
                      <option value="<%= currentStatus %>" selected>
                        <%= currentStatus %>
                      </option>

                      <% nextStatuses.forEach(status=> { %>

                        <option value="<%= status %>">
                          <%= status %>
                        </option>

                        <% }); %>
                          %>
                  </select>


                </td>
                <% if(item.orderStatus=='Return requested' ) {%>
                  <td>
                    <%= item.returnReason %>
                  </td>
                  <% } %>
              </tr>


              <% }) %>
                <% } else { %>
                  <tr>
                    <td colspan="7">No Orders found</td>
                  </tr>
                  <% } %>
        </tbody>
      </table>
      <% } %>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="/js/adminFunctions/orderDetails.js"></script>

    <%- include('../layouts/adminfooter') %>